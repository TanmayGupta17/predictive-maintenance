# Copy to .env and adjust before `docker compose up`. All values have sane
# defaults in docker-compose.yml, so .env is optional for local use.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=predictive_maintenance

# --- Public access ---
# Host port the frontend (nginx) is published on.
PUBLIC_PORT=8080
# Full URL the browser uses to reach the app. Must match how users load it so
# the Socket.IO CORS handshake is accepted. For a domain, set e.g.
# PUBLIC_URL=https://maintenance.example.com
PUBLIC_URL=http://localhost:8080
